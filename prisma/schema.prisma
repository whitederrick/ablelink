// ------------------------------------------------------
// 10. 알람 설정 (Notification Settings)
// ------------------------------------------------------

model UserNotificationSetting {
  id     BigInt @id @default(autoincrement())
  userId BigInt @unique @map("user_id")

  // 출근 알람: 출근 시각 N분 전 (0=비활성)
  clockInAlertMinutes  Int   @default(3) @map("clock_in_alert_minutes")
  // 퇴근 알람: 퇴근 시각 N분 전 (0=비활성)
  clockOutAlertMinutes Int   @default(3) @map("clock_out_alert_minutes")
