  pushSubscription     Json? @map("push_subscription")

  updatedAt DateTime @updatedAt @map("updated_at")

  user Worker @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_notification_settings")
}

// ------------------------------------------------------
// 훈련생/적응지도 종합평가 점수
// ------------------------------------------------------
model TraineeEvaluation {
  id          BigInt   @id @default(autoincrement())
  traineeId   BigInt   @map("trainee_id")
  writerId    BigInt   @map("writer_id")
  evalType    String   @map("eval_type") // "TRAINING" | "ADAPTATION"
  periodStart String   @map("period_start") // YYYY-MM-DD
  periodEnd   String   @map("period_end")
  scores      Json // { WORK_ATTITUDE:[{initial,final}×5], ... }
  comments    Json     @default("{}") // { WORK_ATTITUDE:"...", ... }
  isConfirmed Boolean  @default(false) @map("is_confirmed")
  confirmedAt DateTime? @map("confirmed_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  trainee Trainee @relation(fields: [traineeId], references: [id])
  writer  Worker  @relation(fields: [writerId], references: [id])

  @@index([traineeId, evalType])
  @@map("trainee_evaluations")
}

// ------------------------------------------------------
// 11. 전화번호 OTP 인증 (Phone Verification)
// ------------------------------------------------------

model PhoneVerification {
  id          BigInt   @id @default(autoincrement())
  phoneNumber String   @map("phone_number")
  code        String   @map("code")
  expiresAt   DateTime @map("expires_at")
  verified    Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([phoneNumber])
  @@map("phone_verifications")
}

// ------------------------------------------------------
// 12. 직무지도원 초대 링크 (Worker Invite)
// ------------------------------------------------------

model WorkerInvite {
  id               BigInt    @id @default(autoincrement())
  agencyId         BigInt    @map("agency_id")
  siteId           BigInt?   @map("site_id")
  phoneNumber      String    @map("phone_number")
  workerName       String?   @map("worker_name")
  code             String    @map("code")
  expiresAt        DateTime  @map("expires_at")
  usedAt           DateTime? @map("used_at")
  usedByUserId     BigInt?   @map("used_by_user_id")
  createdByManagerId BigInt      @map("created_by_manager_id")
  createdAt          DateTime    @default(now()) @map("created_at")

  agency  Agency      @relation(fields: [agencyId], references: [id])
  site    Site?       @relation(fields: [siteId], references: [id])
  creator Manager @relation(fields: [createdByManagerId], references: [id])

  @@index([code])
  @@index([agencyId])
  @@map("worker_invites")
}

// ------------------------------------------------------
// 13. 직무지도원 알림 (Worker Notice)
// 관리자가 직무지도원에게 보내는 반려/안내 메시지
// ------------------------------------------------------

model WorkerNotice {
  id        BigInt    @id @default(autoincrement())
  userId    BigInt    @map("user_id")
  agencyId  BigInt    @map("agency_id")
  title     String
  body      String
  type      String    @default("INFO") // INFO | WARN | REJECT
  yearMonth String?   @map("year_month") // 관련 기간 (YYYY-MM)
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user Worker @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([agencyId])
  @@map("worker_notices")
}
