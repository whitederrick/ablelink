generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ------------------------------------------------------
// 1. 공통 및 사용자 관리 (User & Auth)
// ------------------------------------------------------

model CommonCode {
  codeGroup String  @map("code_group")
  codeValue String  @map("code_value")
  codeName  String  @map("code_name")
  sortOrder Int     @default(0) @map("sort_order")
  isActive  Boolean @default(true) @map("is_active")

  @@id([codeGroup, codeValue])
  @@map("common_codes")
}

model Worker {
  id          BigInt     @id @default(autoincrement())
  loginId     String     @unique @map("login_id")
  password    String
  userName    String     @map("user_name")
  phoneNumber String     @map("phone_number")
  role        UserRole   @default(COACH)
  status      UserStatus @default(ACTIVE)

  // ✅ 서비스 플랜 (개인 단위; 프리랜서 전제)
  planType PlanType @default(FREE) @map("plan_type")

  ciKey        String? @unique @map("ci_key")
  signatureUrl String? @map("signature_url") // PREMIUM에서만 사용(정책 레이어에서 강제)
  isTemporary  Boolean @default(false) @map("is_temporary")

  // 온보딩: 이메일로 loginId 변경 시 인증 코드 보관
  pendingLoginId      String?   @map("pending_login_id")
  verifyCode          String?   @map("verify_code")
  verifyCodeExpiresAt DateTime? @map("verify_code_expires_at")

  // 약관 동의 이력
  consentTermsAt    DateTime? @map("consent_terms_at")
  consentPrivacyAt  DateTime? @map("consent_privacy_at")
  consentLocationAt DateTime? @map("consent_location_at")

  createdAt DateTime @default(now()) @map("created_at")

  attendances DailyAttendance[]
  assignments SiteAssignment[]
  writtenLogs TraineeLog[]

  payContracts PayContract[]
  payrollItems PayrollItem[]
  submissions  Submission[]

  confirmedSiteBasePoints SiteBasePoint[]         @relation("UserConfirmedBasePoints")
  DocumentRun             DocumentRun[]
  DocumentVersion         DocumentVersion[]
  DocumentSubmissionLog   DocumentSubmissionLog[]

  attendanceIssueEvents  AttendanceIssueEvent[]  @relation("AttendanceIssueEventActor")
  attendanceEditRequests AttendanceEditRequest[]
  apiCallLogs            ApiCallLog[]

  evaluations         TraineeEvaluation[]
  employmentContracts EmploymentContract[]

  notificationSettings UserNotificationSetting?
  notices              WorkerNotice[]

  @@map("workers")
}

// ------------------------------------------------------
// 2. 사업체 및 현장 관리 (Site & Contact)
// ------------------------------------------------------

model Site {
  id             BigInt  @id @default(autoincrement())
  companyName    String  @map("company_name")
  address        String
  detailAddress  String? @map("detail_address")
  gpsLat         Decimal @map("gps_lat")
  gpsLon         Decimal @map("gps_lon")
  allowanceRange Int     @default(100) @map("allowance_range")

  // ✅ COACH_ENTRY / 클린징 대비
  isVerified     Boolean        @default(true) @map("is_verified")
  siteSourceType SiteSourceType @default(AGENCY)

  // ✅ 중복 최소화/검색 품질 보강
  // - placeId: 지도 API(카카오/네이버/구글 등)의 placeId를 쓰는 경우
  // - normalizedAddressKey: 공백/특수문자 제거 등 서버에서 정규화한 키
  placeId              String? @unique @map("place_id")
  normalizedAddressKey String? @map("normalized_address_key")

  // ✅ 병합(클린징) 링크: 임시(COACH_ENTRY) Site가 정식 Site로 병합될 때 사용
  mergedToSiteId  BigInt? @map("merged_to_site_id")
  mergedToSite    Site?   @relation("SiteMerge", fields: [mergedToSiteId], references: [id])
  mergedFromSites Site[]  @relation("SiteMerge")

  // 기존 기준점 관련 필드 유지
  basePointConfirmed        Boolean                 @default(false) @map("base_point_confirmed")
  basePointSource           String?                 @map("base_point_source")
  basePointAuthority        ApprovalAuthorityType   @default(AGENCY)
  basePointApprovalStatus   BasePointApprovalStatus @default(ORIGINAL_SET)
  basePointAccuracyM        Float?                  @map("base_point_accuracy_m")
  basePointUpdatedAt        DateTime?               @map("base_point_updated_at")
  basePointMemo             String?                 @map("base_point_memo")
  basePointProposedLat      Decimal?
  basePointProposedLon      Decimal?
  basePointProposedByUserId BigInt?
  basePointProposedAt       DateTime?
  basePointDecidedAt        DateTime?
  basePointDecidedById      BigInt?
  basePointDecisionMemo     String?
  basePointCorrectionReason String?

  createdAt DateTime @default(now()) @map("created_at")
  isActive  Boolean  @default(true) @map("is_active")

  // “현재 운영 주체”는 참고용으로 유지 가능(하지만 실귀속은 assignment.agencyId)
  agencyId  BigInt? @map("agency_id")
  managerId BigInt? @map("manager_id")

  // ✅ (구멍 #4 해결) Site에 박혀있던 훈련기간/근무형태 정보 제거
  // - 기간/근무형태는 배정(SiteAssignment) 또는 Placement에 귀속하는 것이 정확함

  currentBasePointId BigInt?        @map("current_base_point_id")
  currentBasePoint   SiteBasePoint? @relation("SiteCurrentBasePoint", fields: [currentBasePointId], references: [id])

  attendances DailyAttendance[]
  assignments SiteAssignment[]
  placements  TraineePlacement[]
  trainees    Trainee[]
  basePoints  SiteBasePoint[]
  contacts    SiteContact[]

  agency        Agency?        @relation(fields: [agencyId], references: [id])
  agencyManager AgencyManager? @relation(fields: [managerId], references: [id])
  DocumentRun   DocumentRun[]
  workerInvites WorkerInvite[]

  @@index([agencyId, isActive])
  @@index([siteSourceType, isVerified])
  @@index([normalizedAddressKey])
  @@map("sites")
}

model SiteContact {
  id          BigInt   @id @default(autoincrement())
  siteId      BigInt   @map("site_id")
  name        String   @map("name")
  email       String?  @map("email")
  phoneNumber String?  @map("phone_number")
  role        String?  @map("role")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId, isActive])
  @@map("site_contacts")
}

// ------------------------------------------------------
// 3. 배정 및 근태 정책 (Assignment & Policy)
// ------------------------------------------------------

model SiteAssignment {
  id     BigInt @id @default(autoincrement())
  userId BigInt @map("user_id")
  siteId BigInt @map("site_id")

  // ✅ 업무 단계 구분 (훈련 PRE/FIELD/적응지도)
  serviceStep ServiceStep @default(FIELD_TRAINING) @map("service_step")

  // ✅ 근태 인증 정책 (에이전시/사이트 방침 반영)
  attendanceMode AttendanceMode @default(APP_GPS) @map("attendance_mode")

  status AssignStatus @default(ACTIVE)

  // ✅ (구멍 #4 해결) 기간/근무형태는 Site가 아니라 Assignment에 귀속
  startDate DateTime  @default(now()) @map("start_date")
  endDate   DateTime? @map("end_date")

  // 선택: 단계별 세부 기간이 필요한 경우(특히 PRE/FIELD 분리 운영용)
  stepStart DateTime? @map("step_start")
  stepEnd   DateTime? @map("step_end")

  // 근무형태: "AM"(09-12) | "PM"(13-17) | "FULL_DAY"(09-18) | "CUSTOM"
  workType                String? @map("work_type")
  // 출퇴근 지도(30분 출근+30분 퇴근) 포함 여부 — AM/PM 기본 true, FULL_DAY 강제 false
  commuteGuidanceIncluded Boolean @default(true) @map("commute_guidance_included")
  // CUSTOM 근무형태일 때 관리자가 직접 설정하는 시작/종료 시각 (HH:MM)
  customWorkStart         String? @map("custom_work_start")
  customWorkEnd           String? @map("custom_work_end")

  assignedAt  DateTime  @default(now()) @map("assigned_at")
  confirmedAt DateTime? @map("confirmed_at")
  rejectedAt  DateTime? @map("rejected_at")
  droppedAt   DateTime? @map("dropped_at")
  endedAt     DateTime? @map("ended_at")

  assignedByManagerId BigInt?      @map("assigned_by_manager_id")
  assignedByManager   Manager? @relation(fields: [assignedByManagerId], references: [id])
  statusReason      String?    @map("status_reason")

  // ✅ 배정 주체 에이전시 명시 (멀티 에이전시 대응)
  agencyId BigInt? @map("agency_id")
  agency   Agency? @relation(fields: [agencyId], references: [id])

  isMainCoach Boolean @default(true) @map("is_main_coach")

  site Site @relation(fields: [siteId], references: [id])
  user Worker @relation(fields: [userId], references: [id])

  attendances        DailyAttendance[]
  submissionRequests SubmissionRequest[]
  DocumentRun        DocumentRun[]
  signTokens         SiteSignToken[]
  holidays           SiteHoliday[]

  @@index([userId, status])
  @@index([siteId, status])
  @@index([agencyId, status])
  @@index([serviceStep, attendanceMode])
  @@map("site_assignments")
}

// ------------------------------------------------------
// 4. 훈련생 및 일지 (Trainee & Log)
// ------------------------------------------------------

model Trainee {
  id                  BigInt        @id @default(autoincrement())
  currentSiteId       BigInt?       @map("current_site_id")
  name                String
  birthDate           String?       @map("birth_date")
  gender              String
  phoneNumber         String?       @map("phone_number")
  guardianPhoneNumber String?
  disabilityType      String        @map("disability_type")
  severity            String
  status              TraineeStatus @default(TRAINING)
  leftAt              DateTime?
  note                String?
  createdAt           DateTime      @default(now()) @map("created_at")

  logs        TraineeLog[]
  placements  TraineePlacement[]
  evaluations TraineeEvaluation[]
  site        Site?               @relation(fields: [currentSiteId], references: [id])

  @@map("trainees")
}

model TraineePlacement {
  id        BigInt @id @default(autoincrement())
  traineeId BigInt @map("trainee_id")
  siteId    BigInt @map("site_id")

  startDate DateTime  @map("start_date")
  endDate   DateTime? @map("end_date")

  // ✅ (구멍 #2 해결) String → Enum
  status TraineePlacementStatus @default(ACTIVE) @map("status")

  site    Site    @relation(fields: [siteId], references: [id])
  trainee Trainee @relation(fields: [traineeId], references: [id])

  @@index([siteId, status])
  @@index([traineeId, status])
  @@map("trainee_placements")
}

// ✅ (구멍 #3 해결) assignment 기준으로 유니크/귀속 강화
model DailyAttendance {
  id     BigInt @id @default(autoincrement())
  userId BigInt @map("user_id")
  siteId BigInt @map("site_id")

  // ✅ assignmentId를 “사실상 필수”로 운영하는 게 안정적
  // - 멀티 배정/멀티 에이전시에서 userId+workDate 유니크는 깨짐
  assignmentId BigInt  @map("assignment_id")
  basePointId  BigInt? @map("base_point_id")

  workDate    String    @map("work_date") // yyyy-mm-dd
  startTime   DateTime? @map("start_time")
  startLocLat Decimal?  @map("start_loc_lat")
  startLocLon Decimal?  @map("start_loc_lon")
  endTime     DateTime? @map("end_time")
  endLocLat   Decimal?  @map("end_loc_lat")
  endLocLon   Decimal?  @map("end_loc_lon")

  startDistanceM Float?   @map("start_distance_m")
  endDistanceM   Float?   @map("end_distance_m")
  withinRange    Boolean? @map("within_range")
  rangeM         Int?     @map("range_m")

  attendanceIssue  AttendanceIssue?
  editRequests     AttendanceEditRequest[]

  isGpsModified        Boolean    @default(false) @map("is_gps_modified")
  status               WorkStatus @default(WORKING)
  isFinalClosed        Boolean    @default(false) @map("is_final_closed")
  finalizedAt          DateTime?  @map("finalized_at") @db.Timestamp(6)
  isManagerFinalClosed Boolean    @default(false) @map("is_manager_final_closed")
  managerFinalAt       DateTime?  @map("manager_final_at")
  managerFinalBy       BigInt?    @map("manager_final_by")

  site Site @relation(fields: [siteId], references: [id])
  user Worker @relation(fields: [userId], references: [id])

  assignment SiteAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  basePoint  SiteBasePoint? @relation(fields: [basePointId], references: [id])

  logs TraineeLog[]

  // ✅ 기존: @@unique([userId, workDate]) → 멀티배정에서 충돌
  // ✅ 변경: assignmentId+workDate로 유니크
  @@unique([assignmentId, workDate])
  @@index([userId, workDate])
  @@index([siteId, workDate])
  @@index([basePointId])
  @@map("daily_attendances")
}

model TraineeLog {
  id                  BigInt  @id @default(autoincrement())
  attendanceId        BigInt  @map("attendance_id")
  traineeId           BigInt  @map("trainee_id")
  writerId            BigInt  @map("writer_id")
  trainingType        String  @map("training_type")
  time1on1            Decimal @default(0) @map("time_1on1")
  timeGroup           Decimal @default(0) @map("time_group")
  content             String?
  evaluation          String? @map("evaluation")
  isCompleted         Boolean @default(false) @map("is_completed")
  extTime1on1         Decimal @default(0) @map("ext_time_1on1")
  extTimeGroup        Decimal @default(0) @map("ext_time_group")
  totalRecognizedTime Decimal @default(0) @map("total_recognized_time")

  tasks      TraineeLogTask[]
  attendance DailyAttendance  @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  trainee    Trainee          @relation(fields: [traineeId], references: [id])
  writer     Worker           @relation(fields: [writerId], references: [id])

  @@index([traineeId])
  @@index([writerId])
  @@map("trainee_logs")
}

model TraineeLogTask {
  id               BigInt  @id @default(autoincrement())
  logId            BigInt  @map("log_id")
  taskName         String  @map("task_name")
  performanceScore Int     @map("performance_score")
  difficulty       String?
  feedback         String? @map("feedback")

  log TraineeLog @relation(fields: [logId], references: [id], onDelete: Cascade)

  @@map("trainee_log_tasks")
}

// ------------------------------------------------------
// 5. 기관 및 관리자 (Agency & Admin)
// ------------------------------------------------------

model Agency {
  id          BigInt   @id @default(autoincrement())
  name        String   @unique @map("name")
  phoneNumber String?  @map("phone_number")
  address     String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  // ✅ 구독 관리
  planType   AgencyPlanType @default(FREE) @map("plan_type")
  maxCoaches Int            @default(0) @map("max_coaches") // 0 = 무제한(PRO)
  maxSites   Int            @default(0) @map("max_sites") // 0 = 무제한(PRO)

  // ✅ 15일 무료 체험
  trialStartedAt DateTime? @map("trial_started_at") // 최초 PREMIUM 기능 사용 시점
  trialEndsAt    DateTime? @map("trial_ends_at") // trialStartedAt + 15일

  // ✅ 토스페이먼츠 구독 연동
  tossCustomerKey String?   @unique @map("toss_customer_key") // 빌링키 발급용 고객 키
  tossBillingKey  String?   @map("toss_billing_key") // 발급된 빌링키 (암호화 저장)
  subscriptionId  String?   @unique @map("subscription_id") // 구독 ID
  nextBillingAt   DateTime? @map("next_billing_at") // 다음 결제일
  subscribedAt    DateTime? @map("subscribed_at") // 최초 구독 전환일

  managers            AgencyManager[]
  managerAccounts     Manager[]
  apiCallLogs         ApiCallLog[]
  sites               Site[]
  assignments         SiteAssignment[]
  payContracts        PayContract[]
  payrollRuns         PayrollRun[]
  employmentContracts EmploymentContract[]
  agencyDeductions    AgencyDeduction[]
  workerInvites       WorkerInvite[]
  supportTickets      SupportTicket[]
  holidayRequests     SiteHolidayRequest[]

  @@index([planType])
  @@map("agencies")
}

model AgencyManager {
  id          BigInt  @id @default(autoincrement())
  agencyId    BigInt  @map("agency_id")
  name        String  @map("name")
  email       String  @map("email")
  phoneNumber String? @map("phone_number")

  agency Agency @relation(fields: [agencyId], references: [id])
  sites  Site[]

  @@map("agency_managers")
}

// 시스템 운영자 (Ablelink 내부 직원만, ADMIN 역할 전용)
model Admin {
  id           BigInt    @id @default(autoincrement())
  loginId      String    @unique @map("login_id")
  passwordHash String    @map("password_hash")
  displayName  String?   @map("display_name")
  isActive     Boolean   @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  systemAuditLogs  SystemAuditLog[]
  announcements    SystemAnnouncement[]
  repliedTickets   SupportTicket[]  @relation("TicketReplier")

  @@map("admins")
}

// 에이전시 관리자 (고객사 담당자, agencyId 필수)
model Manager {
  id           BigInt    @id @default(autoincrement())
  loginId      String    @unique @map("login_id")
  passwordHash String    @map("password_hash")
  displayName  String?   @map("display_name")
  agencyId     BigInt    @map("agency_id")
  signatureUrl String?   @map("signature_url")
  isActive     Boolean   @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  agency Agency @relation(fields: [agencyId], references: [id])

  assignedSiteAssignments SiteAssignment[]
  submissionRequests      SubmissionRequest[]
  confirmedSiteBasePoints SiteBasePoint[]         @relation("ManagerConfirmedBasePoints")
  documentVersions        DocumentVersion[]
  documentSubmissionLogs  DocumentSubmissionLog[]
  attendanceIssueEvents   AttendanceIssueEvent[]  @relation("AttendanceIssueEventManagerActor")
  workerInvites           WorkerInvite[]
  holidayRequests         SiteHolidayRequest[]
  authoredTickets         SupportTicket[]         @relation("TicketAuthor")

  @@index([agencyId])
  @@map("managers")
}

// ------------------------------------------------------
// 6. 문서 및 리포트 (Document LifeCycle)
// ------------------------------------------------------

model DocumentRun {
  id           BigInt  @id @default(autoincrement())
  agencyId     BigInt? @map("agency_id")
  assignmentId BigInt  @map("assignment_id")
  siteId       BigInt  @map("site_id")
  coachUserId  BigInt  @map("coach_user_id")

  docType     DocumentType @map("doc_type")
  periodStart DateTime     @map("period_start")
  periodEnd   DateTime     @map("period_end")

  openAt DateTime @map("open_at")
  dueAt  DateTime @map("due_at")

  status DocumentRunStatus @default(OPEN) @map("status")

  currentVersionId BigInt? @map("current_version_id")

  // 서명 워크플로우 (단계별 서명 추적)
  coachSignedAt       DateTime? @map("coach_signed_at")
  managerSignatureUrl String?   @map("manager_signature_url")
  managerSignedAt     DateTime? @map("manager_signed_at")
  managerSignerName   String?   @map("manager_signer_name")
  agencySignatureUrl  String?   @map("agency_signature_url")
  agencySignedAt      DateTime? @map("agency_signed_at")
  requiresManagerSign Boolean   @default(false) @map("requires_manager_sign")
  // DRAFT | COACH_SIGNED | MANAGER_SIGNED | SUBMITTED | AGENCY_SIGNED
  signStage           String    @default("DRAFT") @map("sign_stage")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  assignment SiteAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  site       Site           @relation(fields: [siteId], references: [id])
  coach      Worker         @relation(fields: [coachUserId], references: [id])

  versions       DocumentVersion[]
  submissionLogs DocumentSubmissionLog[]

  currentVersion DocumentVersion? @relation("DocumentRunCurrentVersion", fields: [currentVersionId], references: [id])

  @@unique([assignmentId, docType, periodStart])
  @@index([agencyId, docType, periodStart])
  @@index([assignmentId, docType])
  @@map("document_runs")
}

model DocumentVersion {
  id          BigInt        @id @default(autoincrement())
  runId       BigInt        @map("run_id")
  versionNo   Int           @map("version_no")
  stage       DocumentStage @map("stage")
  pdfUrl      String        @map("pdf_url")
  pdfFileName String?       @map("pdf_file_name")
  sourceData  Json?         @map("source_data")
  createdAt   DateTime      @default(now()) @map("created_at")

  createdByUserId  BigInt? @map("created_by_user_id")
  createdByManagerId BigInt? @map("created_by_manager_id")

  run               DocumentRun  @relation(fields: [runId], references: [id], onDelete: Cascade)
  createdByUser     Worker?      @relation(fields: [createdByUserId], references: [id])
  createdByManager  Manager?     @relation(fields: [createdByManagerId], references: [id])

  currentForRuns DocumentRun[]           @relation("DocumentRunCurrentVersion")
  submissionLogs DocumentSubmissionLog[]

  @@unique([runId, versionNo])
  @@index([runId, stage, createdAt])
  @@map("document_versions")
}

model DocumentSubmissionLog {
  id        BigInt        @id @default(autoincrement())
  runId     BigInt        @map("run_id")
  versionId BigInt        @map("version_id")
  stage     DocumentStage @map("stage")

  submittedAt        DateTime @default(now()) @map("submitted_at")
  submittedByUserId  BigInt?  @map("submitted_by_user_id")
  submittedByManagerId BigInt?  @map("submitted_by_manager_id")

  sentToEmail  String?   @map("sent_to_email")
  emailSentAt  DateTime? @map("email_sent_at")
  emailStatus  String?   @map("email_status")
  emailPayload Json?     @map("email_payload")

  run               DocumentRun     @relation(fields: [runId], references: [id], onDelete: Cascade)
  version           DocumentVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  submittedByUser   Worker?         @relation(fields: [submittedByUserId], references: [id])
  submittedByManager Manager?       @relation(fields: [submittedByManagerId], references: [id])

  @@index([runId, stage, submittedAt])
  @@index([versionId])
  @@map("document_submission_logs")
}

// ------------------------------------------------------
// 7. 기타 보조 모델 (BasePoint, Pay, Issue, Audit)
// ------------------------------------------------------

model SiteBasePoint {
  id     BigInt @id @default(autoincrement())
  siteId BigInt @map("site_id")

  lat       Decimal @map("lat")
  lon       Decimal @map("lon")
  accuracyM Float?  @map("accuracy_m")

  sourceType BasePointSourceType   @map("source_type")
  stage      BasePointStage        @map("stage")
  authority  ApprovalAuthorityType @map("authority")

  confirmedByUserId  BigInt?  @map("confirmed_by_user_id")
  confirmedByManagerId BigInt?  @map("confirmed_by_manager_id")
  confirmedAt          DateTime @default(now()) @map("confirmed_at")

  memo             String? @map("memo")
  correctionReason String? @map("correction_reason")
  prevBasePointId  BigInt? @map("prev_base_point_id")

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  confirmedByUser    Worker?      @relation("UserConfirmedBasePoints", fields: [confirmedByUserId], references: [id])
  confirmedByManager Manager?     @relation("ManagerConfirmedBasePoints", fields: [confirmedByManagerId], references: [id])

  prevBasePoint  SiteBasePoint?  @relation("BasePointPrev", fields: [prevBasePointId], references: [id])
  nextBasePoints SiteBasePoint[] @relation("BasePointPrev")

  currentForSites Site[]            @relation("SiteCurrentBasePoint")
  attendances     DailyAttendance[]

  @@index([siteId, stage])
  @@index([confirmedByUserId])
  @@index([confirmedByManagerId])
  @@map("site_base_points")
}

model SubmissionRequest {
  id                 BigInt                  @id @default(autoincrement())
  agencyId           BigInt?                 @map("agency_id")
  assignmentId       BigInt                  @map("assignment_id")
  requestedByManagerId BigInt?                 @map("requested_by_manager_id")
  requestedAt          DateTime                @default(now()) @map("requested_at")
  dueDate              DateTime?               @map("due_date")
  status               SubmissionRequestStatus @default(REQUESTED) @map("status")
  memo                 String?                 @map("memo")

  assignment  SiteAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  requestedBy Manager?       @relation(fields: [requestedByManagerId], references: [id])
  submissions Submission[]

  @@index([assignmentId, status])
  @@index([agencyId, status])
  @@map("submission_requests")
}

model Submission {
  id                BigInt   @id @default(autoincrement())
  requestId         BigInt   @map("request_id")
  submittedByUserId BigInt   @map("submitted_by_user_id")
  submittedAt       DateTime @default(now()) @map("submitted_at")
  fileUrl           String?  @map("file_url")
  fileName          String?  @map("file_name")

  request SubmissionRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  user    Worker            @relation(fields: [submittedByUserId], references: [id])

  @@index([requestId, submittedAt])
  @@index([submittedByUserId, submittedAt])
  @@map("submissions")
}

// 사이트별 휴무일 (직무지도원이 등록)
model SiteHoliday {
  id             BigInt   @id @default(autoincrement())
  assignmentId   BigInt   @map("assignment_id")
  date           String   @map("date") // YYYY-MM-DD
  reason         String?  @map("reason")
  countAsWorkday Boolean  @default(false) @map("count_as_workday") // true면 근무 인정
  createdAt      DateTime @default(now()) @map("created_at")

  assignment SiteAssignment      @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  requests   SiteHolidayRequest[]

  @@unique([assignmentId, date])
  @@index([assignmentId])
  @@map("site_holidays")
}

// 사업체담당자 즉석 서명 토큰
model SiteSignToken {
  id           BigInt    @id @default(autoincrement())
  token        String    @unique // UUID 기반 일회용 토큰
  docType      String    @map("doc_type") // attendance-sheet 등
  assignmentId BigInt    @map("assignment_id")
  periodStart  String    @map("period_start") // YYYY-MM-DD
  periodEnd    String    @map("period_end") // YYYY-MM-DD
  signRole     String    @map("sign_role") // company_manager | gov_agent
  signerName   String?   @map("signer_name") // 서명자 이름 표시용
  signatureUrl String?   @map("signature_url") // 서명 완료 후 저장
  usedAt       DateTime? @map("used_at") // 서명 완료 시각
  expiresAt    DateTime  @map("expires_at") // 만료 시각 (기본 7일)
  createdAt    DateTime  @default(now()) @map("created_at")

  assignment SiteAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([assignmentId])
  @@map("site_sign_tokens")
}

// ------------------------------------------------------
// 9. 근로계약서 (Employment Contract)
// ------------------------------------------------------

model EmploymentContract {
  id           BigInt  @id @default(autoincrement())
  agencyId     BigInt  @map("agency_id")
  userId       BigInt  @map("user_id") // 직무지도원
  assignmentId BigInt? @map("assignment_id") // 연결된 배정 (선택)

  // 계약 기간
  contractStart DateTime @map("contract_start")
  contractEnd   DateTime @map("contract_end")

  // 관리자가 미리 입력하는 정보 (미입력 시 직무지도원이 직접 입력)
  siteName                String? @map("site_name") // 배정 사이트명
  workType                String? @map("work_type") // 근무형태
  commuteGuidanceIncluded Boolean @default(true) @map("commute_guidance_included")
  customWorkStart         String? @map("custom_work_start")
  customWorkEnd           String? @map("custom_work_end")

  // 서명 토큰 (카카오 링크 발송용)
  signToken      String    @unique @map("sign_token") // UUID
  tokenSentAt    DateTime? @map("token_sent_at")
  tokenExpiresAt DateTime  @map("token_expires_at")

  // 서명 상태
  status            ContractStatus @default(PENDING) @map("status")
  coachSignedAt     DateTime?      @map("coach_signed_at")
  coachSignatureUrl String?        @map("coach_signature_url")
  adminSignedAt     DateTime?      @map("admin_signed_at")
  adminSignatureUrl String?        @map("admin_signature_url")

  // 직무지도원이 직접 입력한 내용 (관리자 미입력 시)
  coachFilledSiteName String? @map("coach_filled_site_name")
  coachFilledWorkType String? @map("coach_filled_work_type")

  pdfUrl    String? @map("pdf_url")
  adminMemo String? @map("admin_memo")

  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  createdByManagerId BigInt?  @map("created_by_manager_id")

  agency Agency @relation(fields: [agencyId], references: [id])
  user   Worker @relation(fields: [userId], references: [id])

  @@index([agencyId, status])
  @@index([userId, status])
  @@index([signToken])
  @@map("employment_contracts")
}

enum ContractStatus {
  PENDING // 서명 대기
  SIGNED // 직무지도원 서명 완료
  COMPLETED // 쌍방 서명 완료
  CANCELLED // 취소
}

model AuditEvent {
  id         BigInt     @id @default(autoincrement())
  agencyId   BigInt?    @map("agency_id")
  actorType  ActorType  @map("actor_type")
  actorId    BigInt?    @map("actor_id")
  entityType EntityType @map("entity_type")
  entityId   BigInt?    @map("entity_id")
  action     String     @map("action")
  payload    Json?      @map("payload")
  createdAt  DateTime   @default(now()) @map("created_at")

  @@index([agencyId, entityType, entityId])
  @@index([actorType, actorId])
  @@map("audit_events")
}

model PayContract {
  id       BigInt @id @default(autoincrement())
  agencyId BigInt @map("agency_id")
  userId   BigInt @map("user_id")

  // 내부(소속직원) vs 외부 구분 — 4대보험·주휴수당 적용 여부를 결정
  coachType  CoachType  @default(EXTERNAL) @map("coach_type")
  payType    PayType    @map("pay_type")
  baseAmount Decimal    @map("base_amount")
  currency   String     @default("KRW")
  // EXTERNAL에만 적용 (INTERNAL은 항상 BUSINESS)
  incomeType IncomeType @default(BUSINESS) @map("income_type")

  // EXTERNAL + HOURLY에서만 사용
  hourlyRate2Plus  Decimal? @map("hourly_rate_2plus")
  // EXTERNAL에서만 사용 (주 5일 계속 근로 시)
  weeklyHolidayPay Decimal? @map("weekly_holiday_pay")

  effectiveFrom DateTime  @map("effective_from")
  effectiveTo   DateTime? @map("effective_to")

  createdAt DateTime @default(now()) @map("created_at")

  user   Worker @relation(fields: [userId], references: [id])
  agency Agency @relation(fields: [agencyId], references: [id])

  @@index([agencyId, userId, effectiveFrom])
  @@map("pay_contracts")
}

model PayrollRun {
  id        BigInt @id @default(autoincrement())
  agencyId  BigInt @map("agency_id")
  yearMonth String @map("year_month")

  status      PayrollStatus @default(DRAFT) @map("status")
  createdAt   DateTime      @default(now()) @map("created_at")
  finalizedAt DateTime?     @map("finalized_at")

  agency Agency        @relation(fields: [agencyId], references: [id])
  items  PayrollItem[]

  @@unique([agencyId, yearMonth])
  @@map("payroll_runs")
}

model PayrollItem {
  id     BigInt @id @default(autoincrement())
  runId  BigInt @map("run_id")
  userId BigInt @map("user_id")

  grossPay       Decimal @map("gross_pay")
  totalDeduction Decimal @map("total_deduction")
  netPay         Decimal @map("net_pay")

  workedDays    Int?  @map("worked_days")
  workedMinutes Int?  @map("worked_minutes")
  breakdown     Json? @map("breakdown")

  run  PayrollRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  user Worker     @relation(fields: [userId], references: [id])

  @@unique([runId, userId])
  @@map("payroll_items")
}

model AgencyDeduction {
  id       BigInt        @id @default(autoincrement())
  agencyId BigInt        @map("agency_id")
  name     String
  type     DeductionType
  amount   Decimal
  isActive Boolean       @default(true) @map("is_active")
  createdAt DateTime     @default(now()) @map("created_at")

  agency Agency @relation(fields: [agencyId], references: [id])

  @@index([agencyId, isActive])
  @@map("agency_deductions")
}

model InsuranceRates {
  id                  BigInt  @id @default(autoincrement())
  year                Int     @unique
  nationalPension     Decimal @map("national_pension")
  healthInsurance     Decimal @map("health_insurance")
  longTermCare        Decimal @map("long_term_care")
  employmentInsurance Decimal @map("employment_insurance")

  @@map("insurance_rates")
}

model AttendanceIssue {
  id                BigInt @id @default(autoincrement())
  dailyAttendanceId BigInt @unique @map("daily_attendance_id")

  status     AttendanceIssueStatus @default(OPEN)
  issueTypes AttendanceIssueType[] @default([])

  coachReasonText String? @map("coach_reason_text")
  adminMemo       String? @map("admin_memo")

  requestedAt DateTime? @map("requested_at")
  repliedAt   DateTime? @map("replied_at")
  resolvedAt  DateTime? @map("resolved_at")

  updatedAt DateTime @updatedAt @map("updated_at")
  createdAt DateTime @default(now()) @map("created_at")

  dailyAttendance DailyAttendance        @relation(fields: [dailyAttendanceId], references: [id], onDelete: Cascade)
  events          AttendanceIssueEvent[]

  @@index([status, updatedAt])
  @@map("attendance_issues")
}

model AttendanceIssueEvent {
  id      BigInt @id @default(autoincrement())
  issueId BigInt @map("issue_id")

  type      AttendanceIssueEventType
  actorRole AttendanceIssueActorRole @map("actor_role")

  actorUserId    BigInt? @map("actor_user_id")
  actorManagerId BigInt? @map("actor_manager_id")

  message   String?
  createdAt DateTime @default(now()) @map("created_at")

  issue AttendanceIssue @relation(fields: [issueId], references: [id], onDelete: Cascade)

  actorUser    Worker?      @relation("AttendanceIssueEventActor", fields: [actorUserId], references: [id])
  actorManager Manager?     @relation("AttendanceIssueEventManagerActor", fields: [actorManagerId], references: [id])

  @@index([issueId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([actorManagerId, createdAt])
  @@map("attendance_issue_events")
}

// ------------------------------------------------------
// 7a. 시스템 운영 모델들
// ------------------------------------------------------

// 시스템 설정 (DB 기반, Vercel 재배포 없이 변경 가능)
model SystemSetting {
  key       String   @id
  value     String
  label     String?
  updatedAt DateTime @updatedAt @map("updated_at")
  @@map("system_settings")
}

// AI API 호출 로그 (사용량 모니터링)
model ApiCallLog {
  id        BigInt   @id @default(autoincrement())
  agencyId  BigInt?  @map("agency_id")
  userId    BigInt?  @map("user_id")
  service   String                     // "GROQ_STT" | "GEMINI_LOG" | "GEMINI_BATCH"
  success   Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  agency Agency? @relation(fields: [agencyId], references: [id])
  user   Worker? @relation(fields: [userId],   references: [id])

  @@index([agencyId, service, createdAt])
  @@index([createdAt])
  @@map("api_call_logs")
}

// 시스템 공지 (Ablelink → 전체 사용자)
model SystemAnnouncement {
  id        BigInt   @id @default(autoincrement())
  title     String
  body      String
  type      String   @default("INFO") // INFO | MAINTENANCE | URGENT
  adminId   BigInt?  @map("admin_id")
  sentCount Int      @default(0) @map("sent_count")
  createdAt DateTime @default(now()) @map("created_at")

  admin Admin? @relation(fields: [adminId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@map("system_announcements")
}

// ------------------------------------------------------
// 7b. 시스템 감사 로그 (System Audit Log)
// ------------------------------------------------------

model SystemAuditLog {
  id        BigInt   @id @default(autoincrement())
  adminId   BigInt?  @map("admin_id")
  action    String                      // e.g. "AGENCY_PLAN_CHANGED"
  target    String?                     // e.g. "Agency:123"
  detail    String?                     // JSON 형태 상세 정보
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")

  admin Admin? @relation(fields: [adminId], references: [id])

  @@index([adminId, createdAt])
  @@index([createdAt])
  @@map("system_audit_logs")
}

// ------------------------------------------------------
// 7b. 출근부 수정 요청 (직무지도원 → 에이전시 관리자 승인)
// ------------------------------------------------------

model AttendanceEditRequest {
  id           BigInt   @id @default(autoincrement())
  attendanceId BigInt   @map("attendance_id")
  userId       BigInt   @map("user_id")
  reason       String
  proposedStart String? @map("proposed_start") // HH:MM
  proposedEnd   String? @map("proposed_end")   // HH:MM
  status        AttendanceEditReqStatus @default(PENDING)
  adminNote     String? @map("admin_note")
  reviewedAt    DateTime? @map("reviewed_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  attendance DailyAttendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  user       Worker          @relation(fields: [userId], references: [id])

  @@index([attendanceId, status])
  @@index([userId, status])
  @@map("attendance_edit_requests")
}

